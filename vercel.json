{
  "version": 2,
  "builds": [
    { "src": "backend/**/*.js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/$1.js" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
